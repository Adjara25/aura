# ============================================
# AURA — Variables d'environnement
# ============================================
# Copie ce fichier en .env et remplis tes clés
# Supabase depuis : https://app.supabase.com
# Settings → API
# ============================================

# URL de ton projet Supabase
SUPABASE_URL=https://XXXXXXXXXXXXXXXX.supabase.co

# Clé publique anonyme (anon key)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.XXXXXXXXXXXXXXXX

# ============================================
# NOTES DE SÉCURITÉ
# ============================================
# - Ne commit JAMAIS le fichier .env dans git
# - La ANON KEY est publique (safe pour le frontend)
# - La SERVICE_ROLE KEY est secrète (backend uniquement)
# - Ajoute .env dans ton .gitignore
